{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "printWidth": 100,
  "tabWidth": 2,
  "semi": true,
  "singleQuote": false,
  "trailingComma": "all",
  "sortImports": true,
  "sortTailwindcss": true,
  "insertFinalNewline": true,
  "ignorePatterns": ["dist", "reference", "*.md"]
}
